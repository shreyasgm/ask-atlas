# VCS
.git
.gitignore

# Python artifacts
__pycache__
*.py[cod]
*.egg-info
.eggs
dist
build

# Virtual environments
.venv
venv
env

# Tests (not needed in production)
src/tests
src/setup
.pytest_cache
.coverage
htmlcov

# Frontend (deployed separately via Firebase Hosting)
frontend

# IDE / editor
.vscode
.idea

# macOS
.DS_Store
._*

# Docs, design, eval (not needed at runtime)
.claude
.agents
docs
evaluation
*.pen
# Exclude top-level and misc markdown, but keep src/docs/ (runtime) and build files
# NOTE: *.md is intentionally NOT used here because Docker BuildKit in Cloud Build
# does not reliably honour !src/docs/*.md negations. Instead we list specific patterns.
RELEASE_STRATEGY.md
CHANGELOG.md
CONTRIBUTING.md
# Allow files referenced by pyproject.toml (hatchling needs them to build)
# README.md and LICENSE are kept by default (not excluded)

# Data / logs
data
logs
*.csv
*.parquet
chroma_db
archive

# Docker meta (prevent recursive context)
Dockerfile
docker-compose*.yml
.dockerignore
cloudbuild.yaml

# Secrets — NEVER include
.env
.env.*

# Streamlit legacy
.streamlit
app.py

# Caches
.ruff_cache
.mypy_cache
